{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SteelWolf Empire — marketplace.json schema",
  "description": "Anthropic 2026 marketplace definition schema",
  "type": "object",
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "owner": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "url": {"type": "string", "format": "uri"}
      },
      "required": ["name"]
    },
    "metadata": {"type": "object"},
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "source": {"type": "string"},
          "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
          "description": {"type": "string"},
          "author": {"type": "object"},
          "keywords": {"type": "array"}
        },
        "required": ["name", "source"]
      }
    }
  },
  "required": ["name", "plugins"],
  "additionalProperties": true
}
